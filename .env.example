# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored. Never commit secrets.
#
# Settings are loaded by pydantic-settings (see src/fusionserve/config.py).
# All keys are uppercased; nested keys use `__` as the delimiter.

# ---- Application ----
APP_NAME=FusionServe
LOG_LEVEL=INFO
DEBUG=False
BASE_PATH=/api

# ---- PostgreSQL ----
PG_USER=fusionserve
PG_PASSWORD=changeme
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=fusionserve
PG_APP_SCHEMA=app_public
ECHO_SQL=False

# Role used when no Authorization header is present.
ANONYMOUS_ROLE=fusionserve

# ---- Pagination ----
MAX_PAGE_SIZE=1000

# ---- JWT / OIDC ----
# Either set JWKS_URL directly, or set JWT_ISSUER and let the OIDC
# .well-known/openid-configuration document supply jwks_uri.
# JWT_ISSUER=https://auth.example.com/realms/myrealm
# JWKS_URL=https://auth.example.com/realms/myrealm/protocol/openid-connect/certs
# CLIENT_ID=fusionserve
